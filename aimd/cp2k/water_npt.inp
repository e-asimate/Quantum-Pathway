&GLOBAL
  PROJECT water_npt
  RUN_TYPE MD
  PRINT_LEVEL LOW
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &MGRID
      CUTOFF 600
      NGRIDS 5
      REL_CUTOFF 60
    &END MGRID
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-6
      &OT
        MINIMIZER DIIS
        PRECONDITIONER FULL_ALL
      &END OT
    &END SCF
    &XC
      &XC_FUNCTIONAL SCAN
      &END XC_FUNCTIONAL
      &VDW_POTENTIAL
        POTENTIAL_TYPE NON_LOCAL
        &NON_LOCAL
          TYPE RVV10
          PARAMETERS 6.3 0.0093
        &END NON_LOCAL
      &END VDW_POTENTIAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.4 12.4 12.4
      PERIODIC XYZ
    &END CELL
    &TOPOLOGY
      COORD_FILE_FORMAT PDB
      COORD_FILE_NAME __COORD__
    &END TOPOLOGY
    &KIND H
      BASIS_SET TZV2P-MOLOPT-GTH
      POTENTIAL GTH-PBE
    &END KIND
    &KIND O
      BASIS_SET TZV2P-MOLOPT-GTH
      POTENTIAL GTH-PBE
    &END KIND
  &END SUBSYS
&END FORCE_EVAL

&MOTION
  &MD
    ENSEMBLE NPT_F
    STEPS 40000
    TIMESTEP 0.5
    TEMPERATURE 298.0
    &BAROSTAT
      PRESSURE 1.0
      TIMECON 1000.0
      TYPE MTK
    &END BAROSTAT
    &THERMOSTAT
      TYPE NOSE
      &NOSE
        TIMECON 1000.0
        LENGTH 3
      &END NOSE
    &END THERMOSTAT
  &END MD
  &PRINT
    &RESTART
      BACKUP_COPIES 3
      EACH 1000
    &END RESTART
    &TRAJECTORY
      FORMAT DCD
      EACH 50
    &END TRAJECTORY
    &VELOCITIES OFF
    &FORCES OFF
  &END PRINT
&END MOTION

